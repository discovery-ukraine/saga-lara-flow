includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    ignoreErrors:
        # env() in the published config file is the intended Laravel pattern.
        # Larastan cannot resolve the framework config directory in a package context.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/saga-lara-flow.php
